#!/bin/sh
set -e

# Stop and disable the service if it's being removed, not upgraded
if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    systemctl stop caddy || true
    systemctl disable caddy || true
    systemctl daemon-reload
fi

# Remove the caddy user and group only if the package is being purged
if [ "$1" = "purge" ]; then
    if getent passwd caddy >/dev/null; then
        userdel -r caddy || true
    fi
    if getent group caddy >/dev/null; then
        groupdel caddy || true
    fi
fi

exit 0
