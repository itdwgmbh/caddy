#!/bin/sh
set -e

# Create the group if it doesn't exist
if ! getent group caddy >/dev/null; then
    groupadd --system caddy
fi

# Create the user if it doesn't exist
if ! id -u caddy >/dev/null 2>&1; then
    useradd --system \
        --gid caddy \
        --create-home \
        --home-dir /var/lib/caddy \
        --shell /usr/sbin/nologin \
        --comment "Caddy web server" \
        caddy
fi

# Set proper ownership
chown -R caddy:caddy /var/lib/caddy || true
chown -R caddy:caddy /var/log/caddy || true

# Reload systemd to pick up the new service
systemctl daemon-reload

# On new installation, enable the service
if [ "$1" = "configure" ] && [ -z "$2" ]; then
    # This is a new installation
    systemctl enable caddy
    
    # Install default Caddyfile if it doesn't exist
    if [ ! -f /etc/caddy/Caddyfile ]; then
        cp /etc/caddy/Caddyfile.dpkg-new /etc/caddy/Caddyfile || true
    fi
else
    # This is an upgrade - restart the service
    systemctl restart caddy || true
fi

# Trust the Caddy root certificate (only on new installs)
if [ "$1" = "configure" ] && [ -z "$2" ]; then
    /usr/bin/caddy trust || true
fi

exit 0